# coaching-app-web — required environment variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Used by /api/contact to persist messages to the contact_messages table
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Internal admin guard ──────────────────────────────────────────────────────
ADMIN_SECRET=<random-secret>
ADMIN_EMAIL=admin@yourdomain.com

# ── Stripe (for pricing page + registration) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# ── App URL (used in emails and redirects) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.unitlift.com
